# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Xero OAuth 2.0
XERO_CLIENT_ID=your-xero-client-id
XERO_CLIENT_SECRET=your-xero-client-secret
# XERO_REDIRECT_URI is auto-detected from request context — only set for explicit override
# XERO_REDIRECT_URI=http://localhost:3000/api/xero/callback

# QuickBooks Online OAuth 2.0
QBO_CLIENT_ID=your-quickbooks-client-id
QBO_CLIENT_SECRET=your-quickbooks-client-secret
QBO_REDIRECT_URI=https://localhost:3000/api/quickbooks/callback
QBO_SANDBOX=false

# Encryption (for token storage — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
TOKEN_ENCRYPTION_KEY=your-64-char-hex-key

# Anthropic (for Chat Scenario Builder)
ANTHROPIC_API_KEY=your-anthropic-api-key

# App (only set in production — auto-detected in dev)
# NEXT_PUBLIC_APP_URL=https://your-production-domain.com
